# Copy to .env or set in your environment. Do not commit real values.

# Database (Aiven MySQL)
# SPRING_DATASOURCE_URL=jdbc:mysql://YOUR_HOST:PORT/defaultdb?ssl-mode=REQUIRED
# SPRING_DATASOURCE_USERNAME=avnadmin
# SPRING_DATASOURCE_PASSWORD=your_password

# JWT (use a long random string in production)
# JWT_SECRET=your-256-bit-secret-at-least-32-characters

# CORS (comma-separated origins)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Stripe (for paid courses)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# YouTube Data API (for seed script only)
# YOUTUBE_API_KEY=your_api_key
